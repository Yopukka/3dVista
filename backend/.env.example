# Backend environment variables.
# Copy to a real .env (gitignored) and export these before running in production.
# LOCAL DEMO: none of these are required — safe defaults are used when unset.

# --- Production-critical ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=
# Must be False in production (default True for local demo).
DJANGO_DEBUG=False
# Comma-separated hostnames (required when DEBUG=False).
DJANGO_ALLOWED_HOSTS=admin.example.com
# Comma-separated allowed frontend origins for CORS.
CORS_ALLOWED_ORIGINS=https://admin.example.com

# --- Public ingest endpoint (/api/results/receive/) ---
# When set, 3DVista tours must send it as the X-Ingest-Token header.
# Strongly recommended in production. Generate like the secret key above.
INGEST_TOKEN=

# --- Optional tuning (sensible defaults shown) ---
ACCESS_TOKEN_MINUTES=60
THROTTLE_ANON=30/min
THROTTLE_USER=120/min
THROTTLE_LOGIN=10/min
THROTTLE_INGEST=60/min

# --- Superuser bootstrap (used by manage.py createsuperuser --noinput) ---
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=
DJANGO_SUPERUSER_EMAIL=admin@example.com
